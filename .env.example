NODE_ENV=development
PORT=3001
API_PREFIX=api/v1
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:5173,https://sendiaba-mvp-front.vercel.app

# URL du front pour les liens dans les e-mails (validation inscription)
FRONTEND_HOME_URL=http://localhost:3000

DATABASE_URL="postgresql://postgres:password@localhost:5432/sendiaba_dev?schema=public"

JWT_ACCESS_SECRET=your_access_secret
JWT_ACCESS_EXPIRES_IN=3600s
JWT_REFRESH_SECRET=your_refresh_secret
JWT_REFRESH_EXPIRES_IN=7d

UPLOAD_DEST=./uploads
# URL publique de l API (sans slash final) — pour les URLs d upload local si CLOUDINARY_URL est vide
PUBLIC_BASE_URL=http://localhost:3001
MAX_FILE_SIZE_MB=5

CDN_BASE_URL=https://cdn.sendiaba.com

# Images (uploads) — cloudinary://API_KEY:API_SECRET@CLOUD_NAME
CLOUDINARY_URL=

# SMTP (inscription / validation e-mail)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
# Mot de passe d'application Gmail : mettre entre guillemets si il contient des espaces
# MAIL_FROM ou SMTP_FROM (expéditeur affiché)
MAIL_FROM=no-reply@sendiaba.com
SMTP_FROM=

# DEXPAY (https://docs.dexpay.africa — clés depuis portal.dexpay.africa > Développeurs > Clés API)
# Checkout session : DEXPAY_API_KEY uniquement.
# Liste des opérateurs + transaction-attempt : DEXPAY_API_KEY + DEXPAY_API_SECRET.
DEXPAY_API_URL=https://api.dexpay.africa/api/v1
DEXPAY_API_KEY=
DEXPAY_API_SECRET=
# URLs de retour : DEXPAY rejette http://localhost (422). Laisser vide pour dériver depuis FRONTEND_HOME_URL (HTTPS).
# DEXPAY_SUCCESS_URL=
# DEXPAY_FAILURE_URL=
# URL publique HTTPS de cette API pour webhook DEXPAY (obligatoire : localhost refusé). Ex. https://xxx.ngrok-free.app/api/v1 ou déploiement Render.
# API_PUBLIC_URL=

# --- Render.com ---
# PORT est injecte automatiquement par Render : ne pas le definir dans le dashboard.
# DATABASE_URL : Postgres Render, Neon, Supabase, etc. (souvent ?sslmode=require en fin d URL)
# CORS_ORIGINS : inclure l URL du front de prod (ex. https://xxx.vercel.app).
# RENDER_EXTERNAL_URL : injecte par Render (URL du service) — ajoutee automatiquement aux origines CORS pour Swagger.
# API_PUBLIC_URL : optionnel si domaine API personnalise (en plus de RENDER_EXTERNAL_URL).
# Health check : GET /api/v1/health
# Build (render.yaml) : install pnpm via get.pnpm.io (pas corepack enable — EROFS sur Render)
# Demarrage : npx prisma migrate deploy && npm run start:prod
